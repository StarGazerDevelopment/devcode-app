{
  "name": "devcode",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "author": "StarGazerDevelopment",
  "description": "DevCode IDE",
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:web": "vite",
    "dev:server": "node server/index.mjs",
    "dev:electron": "wait-on tcp:5173 tcp:3030 && electron electron/main.cjs",
    "dev:desktop": "concurrently -k \"npm:dev:server\" \"npm:dev:web\" \"npm:dev:electron\"",
    "build:server": "esbuild server/index.mjs --bundle --platform=node --target=node18 --format=cjs --outfile=dist-server/index.cjs --external:fsevents --external:node-pty",
    "build": "tsc -b && vite build && npm run build:server",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server/index.mjs",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.stargazer.devcode",
    "productName": "DevCode",
    "directories": {
      "output": "../Installer"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron/**/*",
      ".devcode",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/logo.png"
    },
    "npmRebuild": false,
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DevCode",
      "artifactName": "installer.exe"
    },
    "asarUnpack": [
      "server/**/*",
      "node_modules/node-pty/**/*"
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^1.11.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "main": "electron/main.cjs"
}
